<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
  xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.6.xsd">

  <changeSet id="admin-2phase-zkp_credential_definition" author="yklee0911">
    <createTable tableName="zkp_credential_definition">
      <column name="id" type="bigint" autoIncrement="true">
        <constraints primaryKey="true" nullable="false" />
      </column>
      <column name="definition_id" type="varchar(100)">
        <constraints nullable="false" unique="true"/>
      </column>
      <column name="schema_id" type="varchar(100)">
        <constraints nullable="false" unique="false"/>
      </column>
      <column name="type" type="varchar(50)" defaultValue="CL">
        <constraints nullable="false" unique="false"/>
      </column>
      <column name="alias" type="varchar(50)">
        <constraints nullable="false" unique="false"/>
      </column>
      <column name="tag" type="varchar(100)">
        <constraints nullable="false" unique="false"/>
      </column>
      <column name="version" type="varchar(10)">
        <constraints nullable="false" unique="false"/>
      </column>
      <column name="definition" type="text">
        <constraints nullable="false" unique="false"/>
      </column>
      <column name="status" type="varchar(50)">
        <constraints nullable="false" unique="false"/>
      </column>
      <column name="zkp_schema_id" type="bigint">
        <constraints nullable="false" unique="false"/>
      </column>
      <column name="created_at" type="timestamp" defaultValue="NOW()">
        <constraints nullable="false" unique="false"/>
      </column>
      <column name="updated_at" type="timestamp">
        <constraints nullable="true" unique="false"/>
      </column>
    </createTable>
  </changeSet>

</databaseChangeLog>