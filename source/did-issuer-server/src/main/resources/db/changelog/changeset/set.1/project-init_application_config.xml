<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
  xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.6.xsd">


    <changeSet id="init-application_config" author="gwnam" >
        <createTable tableName="application_config">
            <column name="id" type="bigint" autoIncrement="true">
                <constraints primaryKey="true" nullable="false" />
            </column>
            <column name="tas_url" type="varchar(2000)">
                <constraints nullable="true" unique="false" />
            </column>
            <column name="assert_key_id" type="varchar(30)">
                <constraints nullable="true" unique="false" />
            </column>
            <column name="revoke_auth_type" type="varchar(30)">
                <constraints nullable="true" unique="false" />
            </column>
            <column name="created_at" type="timestamp" defaultValue="NOW()">
                <constraints nullable="false" unique="false"/>
            </column>
            <column name="updated_at" type="timestamp">
                <constraints nullable="true" unique="false"/>
            </column>
        </createTable>
    </changeSet>


</databaseChangeLog>
