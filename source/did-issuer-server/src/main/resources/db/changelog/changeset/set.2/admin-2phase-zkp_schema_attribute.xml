<?xml version="1.0" encoding="utf-8"?>
<databaseChangeLog
  xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-3.6.xsd">

  <changeSet id="admin-2phase-zkp_schema_attribute" author="yklee0911">
    <createTable tableName="zkp_schema_attribute">
      <column name="id" type="bigint" autoIncrement="true">
        <constraints primaryKey="true" nullable="false" />
      </column>
      <column name="schema_id" type="varchar(100)">
        <constraints nullable="false" unique="false"/>
      </column>
      <column name="attribute_label" type="varchar(100)">
        <constraints nullable="false" unique="false"/>
      </column>
      <column name="namespace_id" type="varchar(100)">
        <constraints nullable="false" unique="false"/>
      </column>
      <column name="sort_order" type="smallint">
        <constraints nullable="false" unique="false"/>
      </column>
      <column name="zkp_attribute_id" type="bigint">
        <constraints nullable="false" unique="false"/>
      </column>
      <column name="zkp_schema_id" type="bigint">
        <constraints nullable="false" unique="false"/>
      </column>
    </createTable>
  </changeSet>

</databaseChangeLog>